APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kbeauty
DB_USERNAME=postgres
DB_PASSWORD=
# Alternative : une seule DB_URL (ex. Neon) prend le dessus sur les variables ci-dessus.
# Utiliser une connexion directe, jamais un pooler en mode "transaction" (casse les migrations).
# DB_URL=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=

LOW_STOCK_THRESHOLD=5

# Cloudflare R2 (compatible S3) - stockage des factures en prod.
# En local, INVOICES_DISK=local suffit, ces variables peuvent rester vides.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true
INVOICES_DISK=local

# Mentions légales affichées sur les factures - à remplir avant la prod.
COMPANY_NAME=
COMPANY_LEGAL_FORM=
COMPANY_ADDRESS_LINE1=
COMPANY_ADDRESS_LINE2=
COMPANY_POSTAL_CODE=
COMPANY_CITY=
COMPANY_COUNTRY=France
COMPANY_SIRET=
COMPANY_VAT_NUMBER=
COMPANY_EMAIL=

CLOUDINARY_URL=

# Clés de test Stripe (dashboard Stripe > Developers > API keys / Webhooks).
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Recherche catalogue (Laravel Scout). Sans Meilisearch configuré, Scout retombe sur le
# driver "collection" (recherche en mémoire, sans infra) — suffisant en local/CI.
# SCOUT_DRIVER=meilisearch
# MEILISEARCH_HOST=http://127.0.0.1:7700
# MEILISEARCH_KEY=

VITE_APP_NAME="${APP_NAME}"
VITE_STRIPE_KEY="${STRIPE_KEY}"
